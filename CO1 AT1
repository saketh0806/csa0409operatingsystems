C CODE 
#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int fd;
    char buffer[100];
    int bytes;

    fd = open("student.txt", O_RDONLY);

    bytes = read(fd, buffer, sizeof(buffer)-1);

    buffer[bytes] = '\0';

    printf("%s", buffer);

