1) START
Create child process using fork()

IF child process THEN
    Display Child PID
ELSE
    Display Parent PID
END IF

STOP
C CODE
#include <stdio.h>
#include <unistd.h>

int main()
{
    pid_t pid;

    pid = fork();

    if(pid == 0)
    {
        printf("Child Process\n");
        printf("Child PID = %d\n", getpid());
        printf("Parent PID = %d\n", getppid());
    }
    else
    {
        printf("Parent Process\n");
        printf("Parent PID = %d\n", getpid());
    }

    return 0;
}

